generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  ADMIN
}

enum GalleryCategory {
  FISH
  PRODUCTION
}

// ─── Models ─────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())

  @@map("users")
}

model News {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  featured    Boolean  @default(false)
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  titleRu       String
  titleEn       String
  titleZh       String
  descriptionRu String
  descriptionEn String
  descriptionZh String
  contentRu     String
  contentEn     String
  contentZh     String
  thumbnailUrl  String?

  images NewsImage[]

  @@map("news")
}

model NewsImage {
  id     Int    @id @default(autoincrement())
  newsId Int
  url    String
  order  Int    @default(0)

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@map("news_images")
}

model Product {
  id        Int      @id @default(autoincrement())
  nameRu    String
  nameEn    String
  nameZh    String
  category  String
  price     Decimal  @db.Decimal(10, 2)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks ProductStock[]

  @@map("products")
}

model Supplier {
  id      Int     @id @default(autoincrement())
  name    String
  logoUrl String?
  active  Boolean @default(true)
  order   Int     @default(0)

  stocks ProductStock[]

  @@map("suppliers")
}

model ProductStock {
  id         Int     @id @default(autoincrement())
  productId  Int
  supplierId Int
  weightKg   Decimal @db.Decimal(10, 2)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@map("product_stocks")
}

model Partner {
  id      Int     @id @default(autoincrement())
  name    String
  logoUrl String
  active  Boolean @default(true)
  order   Int     @default(0)

  @@map("partners")
}

model GalleryImage {
  id       Int             @id @default(autoincrement())
  url      String
  category GalleryCategory
  order    Int             @default(0)

  @@map("gallery_images")
}

model Announcement {
  id       Int     @id @default(autoincrement())
  imageUrl String
  link     String?
  active   Boolean @default(true)
  order    Int     @default(0)

  @@map("announcements")
}

model ContactRequest {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_requests")
}

model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Json

  @@map("site_settings")
}
